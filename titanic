# numpy for numerical operations and pandas for data manipulation.
import numpy as np
import pandas as pd

# Loads the 'titanic.csv' file into a pandas DataFrame
df=pd.read_csv("titanic.csv")

# Displays the first 5 rows of the DataFrame `df` to get a quick overview of the data.
print(df.head())

# Displays the last 5 rows of the DataFrame
print(df.tail())

# Prints the dimensions (number of rows and columns) of the DataFrame
print(df.shape)

# Prints the names of all columns in the DataFrame
print(df.columns)

# Calculates and displays the count of missing (null) values for each column.
print(df.isnull().sum())

# Fills missing 'Age' values with the mean age of the column.
df["Age"] = df["Age"].fillna(df["Age"].mean())

# Re-checks and displays the count of missing values after filling 'Age'.
print(df.isnull().sum())

# Removes all rows containing any missing values from the DataFrame. `inplace=True` modifies the DataFrame directly.
df.dropna(inplace=True)

# Filters and displays rows where 'Age' is greater than 30.
print(df[df['Age']>30])

# Filters and displays rows where 'Sex' is 'female'.
print(df[df['Sex']=="female"])

# prints the mean survival rate grouped by 'Sex'.
print(df.groupby('Sex')["Survived"].mean())

# Sorts the DataFrame by 'Age' in ascending order
df_sorted=df.sort_values(by="Age",ascending=True)
print(df_sorted.head())

# A new 'family_size' column by summing 'SibSp'  and 'Parch'
df['family_size']=df["SibSp"]+df["Parch"]
print(df.head())

# Prints the maximum 'Fare' value from the DataFrame.
print(df['Fare'].max())

# Saves the current DataFrame to a new
df.to_csv("cleaned dataset.scv")

# Imports `seaborn` and `matplotlib.pyplot` for data visualization.
import seaborn as sns
import matplotlib.pyplot as plt

# visualizes the survival rate as a bar chart.
Survival_rate=df["Survived"].value_counts(normalize=True)*100
Survival_rate.plot(kind="bar")
plt.title("Survival percentage")
plt.xlabel("Survived")
plt.ylabel("Percentage")
plt.show()

# The survival rate is approximately 66.3%.

# Bar plot to show the survival rate based on gender.
sns.barplot(x="Sex",y="Survived",data=df)
plt.title("Survival Rate by Gender")
plt.show()

# Observation: A higher percentage of females survived compared to males.

#  A box plot to visualize the fare distribution across passenger classes.
sns.boxplot(x="Pclass",y="Fare",data=df)
plt.title("Fare Distribution by Passenger Class")
plt.show()

# survival rate by family size using a bar plot.
df["Family_size"]=df["SibSp"]+df["Parch"]
sns.barplot(x="Family_size",y="Survived",data=df)
plt.title("Survival Rate by Family Size")
plt.show()

# histogram to show the distribution of passenger ages.
sns.histplot(df["Age"],color="purple")
plt.title("Age Distribution")
plt.show()

# histogram of age distribution, differentiated by survival status
sns.histplot(data=df,x="Age",hue="Survived",palette=["gray","blue"],bins=20)
plt.title("Age Distribution by Survival")
plt.show()

# pie chart to visualize the survival percentage
Survival=df["Survived"].value_counts()
plt.pie(Survival,labels=["Not survived","survived"],autopct="%1.1f%%",colors=["blue","green"])
plt.title("survival percentage")
plt.show()

# scatter plot to visualize the relationship between 'Age' and 'Fare'.
sns.scatterplot(x="Age",y="Fare",data=df)
plt.title("Age vs Fare")
plt.show()

# sklearn Model selection,LogisticRegression and metrics
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score,confusion_matrix

df["Embarked"] = df["Embarked"].fillna("S")

# Fills missing 'Cabin' values with 'unknown'.
df["Cabin"] = df["Cabin"].fillna("unknown")

# Converts 'Sex' (male/female) and 'Embarked' (S/C/Q) categorical features to numerical representations
# fills any remaining NaNs in the entire DataFrame with 0.
df["Sex"]=df["Sex"].map({"male":0,"female":1})
df["Embarked"]=df["Embarked"].map({"S":0,"C":1,"Q":2})
df.fillna(0,inplace=True)

#  dropping non-predictive column
x=df.drop(["Survived", "Name", "Ticket", "PassengerId", "Cabin"],axis=1)
y=df["Survived"]

# Splits the data into training
x_train,x_test,y_train,y_test=train_test_split(x,y,test_size=0.2,random_state=42)

# Initializes a Logistic Regression model with a maximum iteration limit of 1000 and then trains it on the training data.
model=LogisticRegression(max_iter=1000)
model.fit(x_train,y_train)

# trained Logistic Regression model to make predictions on the test set features.
y_pred=model.predict(x_test)

# prints the accuracy score of the model's predictions
print("accuracy:",accuracy_score(y_test,y_pred))

#  confusion matrix  to evaluate model performance, then visualizes it using a seaborn heatmap.
cm=confusion_matrix(y_test,y_pred)
sns.heatmap(cm,annot=True,fmt="d")
plt.title("confusion matrix")
plt.show()
